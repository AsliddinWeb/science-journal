# ── Copy this file to .env.prod and fill in real values ──

# Database
POSTGRES_DB=journal_db
POSTGRES_USER=journal_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
DATABASE_URL=postgresql+asyncpg://journal_user:CHANGE_ME_strong_password_here@db:5432/journal_db
SYNC_DATABASE_URL=postgresql://journal_user:CHANGE_ME_strong_password_here@db:5432/journal_db

# Redis
REDIS_URL=redis://redis:6379/0

# JWT — generate a long random key with: openssl rand -hex 64
SECRET_KEY=CHANGE_ME_to_a_very_long_random_secret_at_least_64_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# SMTP (required for email notifications, password reset, etc.)
MAIL_USERNAME=noreply@science.asliddin.me
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=noreply@science.asliddin.me
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=Science and Innovation Journal
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# App
APP_NAME=Science and Innovation Journal
APP_URL=https://science.asliddin.me
ALLOWED_ORIGINS=https://science.asliddin.me,https://www.science.asliddin.me
DEBUG=False
