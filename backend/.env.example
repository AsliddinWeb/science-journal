# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/journal_db
SYNC_DATABASE_URL=postgresql://postgres:postgres@db:5432/journal_db

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=change-me-to-a-very-long-random-secret-key-at-least-64-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# S3 / MinIO
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=journal-files
S3_REGION=us-east-1

# SMTP
MAIL_USERNAME=noreply@yourjournal.com
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=noreply@yourjournal.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=Science and Innovation Journal
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# App
APP_NAME=Science and Innovation Journal
APP_URL=https://yourjournal.com
ALLOWED_ORIGINS=http://localhost:5173,https://yourjournal.com
DEBUG=False
