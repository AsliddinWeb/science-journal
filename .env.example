# ╔═══════════════════════════════════════════════════════════════╗
# ║   IlmiyJurnal — Single .env file for all services             ║
# ║   Copy to .env and fill in real values                        ║
# ╚═══════════════════════════════════════════════════════════════╝

# ── Database (Postgres) ──
POSTGRES_DB=journal_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/journal_db
SYNC_DATABASE_URL=postgresql://postgres:postgres@db:5432/journal_db

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── JWT — generate with: openssl rand -hex 64 ──
SECRET_KEY=change-me-to-a-very-long-random-secret-key-at-least-64-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── SMTP (email notifications, password reset) ──
MAIL_USERNAME=noreply@yourjournal.com
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=noreply@yourjournal.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_FROM_NAME=Science and Innovation Journal
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# ── App ──
APP_NAME=Science and Innovation Journal
APP_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
DEBUG=True
